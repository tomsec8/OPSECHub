{
  "manifest_version": 3,
  "name": "OPSECHub",
  "version": "1.0.0.0",
  "description": "Advanced OPSEC & Privacy Shield \u2013 Protect your digital footprint during OSINT operations and everyday browsing.",
  "author": "TomSec8",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "permissions": [
    "webRequest",
    "storage",
    "tabs",
    "activeTab",
    "scripting",
    "declarativeNetRequest",
    "declarativeNetRequestWithHostAccess",
    "declarativeNetRequestFeedback",
    "browsingData",
    "cookies",
    "proxy",
    "privacy",
    "webNavigation",
    "alarms",
    "clipboardWrite",
    "contentSettings"
  ],
  "optional_permissions": [
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "declarative_net_request": {
    "rule_resources": [
      { "id": "Core_Light_1", "enabled": false, "path": "rules/Core/Light/Core_Light_1.json" },
      { "id": "Core_Light_2", "enabled": false, "path": "rules/Core/Light/Core_Light_2.json" },
